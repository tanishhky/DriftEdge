# DriftEdge — Environment variables template
# Copy to `.env` and fill in real values. `.env` is gitignored.

# ── Polymarket ──────────────────────────────────────────────────────────────
# Read-only market data (orderbook, prices, trades, markets) requires NO key.
# These are only needed if/when we want to PLACE orders or sign authenticated
# requests via py-clob-client.

# Public address (the 0x... of your trading wallet). Needed for L2 auth.
POLYMARKET_WALLET_ADDRESS=

# CLOB API credentials — derive these via py-clob-client's create_api_key()
# after authenticating with a wallet. They are NOT directly the wallet keys.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# ── Kalshi ──────────────────────────────────────────────────────────────────
# Read-only market data (orderbook, prices, markets, events, series) requires
# NO key. The fields below are only needed for AUTHENTICATED endpoints
# (account info, portfolio, trading).
#
# Kalshi uses RSA-PSS request signing. Generate an API key pair at:
#   https://kalshi.com/account/profile (Developer / API Keys)
# Download the private key PEM file once — Kalshi does not store it.

KALSHI_ENV=prod                          # prod | demo
KALSHI_API_KEY_ID=                       # UUID-style identifier
KALSHI_PRIVATE_KEY_PATH=                 # absolute path to the .pem file

# ── Runtime config ─────────────────────────────────────────────────────────
DRIFTEDGE_DATA_DIR=./data
DRIFTEDGE_LOG_DIR=./logs
DRIFTEDGE_LOG_LEVEL=INFO

# Polling cadence for orderbook snapshots (seconds). Polymarket has no
# documented strict limit on read endpoints, but be polite.
DRIFTEDGE_POLL_INTERVAL_S=60

# Default fractional-Kelly multiplier (0.25 = quarter-Kelly).
DRIFTEDGE_KELLY_FRACTION=0.25

# Default entry/exit zones for path trades.
DRIFTEDGE_ENTRY_LOW=0.30
DRIFTEDGE_ENTRY_HIGH=0.40
DRIFTEDGE_EXIT_TARGET=0.60
DRIFTEDGE_STOP_LOW=0.20
