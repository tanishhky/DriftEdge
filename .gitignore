# ── Secrets ────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
credentials.json
token.json
client_secret_*.json
*wallet*.json

# ── Data caches (regenerable, large) ───────────────────────────────────────
/data/
!/data/.gitkeep
*.parquet
*.feather
*.csv.gz

# ── Runtime logs ───────────────────────────────────────────────────────────
/logs/
!/logs/.gitkeep
*.log

# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# ── Virtual envs ───────────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── IDE / editor ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ─────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Jupyter ────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# machine-specific launchd config (absolute paths) — keep local only
scripts/launchd/*.plist
